BAPONI_API_KEY=sk-us-...
# Optional: override default https://api.baponi.ai (e.g. for staging)
# BAPONI_BASE_URL=https://staging.console.baponi.dev
# Optional: explicit python interpreter inside the sandbox image. Required
# when the image's python is not auto-detected (e.g. cbioportal/biomni
# ships python under /opt/conda/envs/biomni/bin/ which Baponi doesn't
# add to its language list automatically).
# BAPONI_PYTHON_BIN=/opt/conda/envs/biomni/bin/python

# LLM (LM Studio defaults shown). For Anthropic, set ANTHROPIC_API_KEY and
# adjust examples/admet.py to drop source/base_url and use a claude-* model.
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=qwen3.6-35b-a3b-nvfp4
